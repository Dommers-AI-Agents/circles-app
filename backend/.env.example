# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=3001

# JWT Configuration (Required)
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRE=30d

# Google Services
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Firebase Configuration (Required)
# These values come from your Firebase project settings
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account-email@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=your-cert-url

# LinkedIn OAuth (Optional)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Google Cloud Storage (Required for image uploads)
GCS_BUCKET_NAME=your-bucket-name
GCS_PROJECT_ID=your-gcs-project-id

# MongoDB Configuration (If using MongoDB instead of Firestore)
MONGODB_URI=mongodb://localhost:27017/circles

# Apple Sign In (Optional)
APPLE_TEAM_ID=your-apple-team-id
APPLE_SERVICE_ID=your-apple-service-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Apple-Private-Key-Here\n-----END PRIVATE KEY-----\n"

# Frontend URLs (for CORS and redirects)
FRONTEND_URL=http://localhost:3000
APP_SCHEME=circles://

# Cloud Run specific (set automatically by Cloud Run)
# PORT=8080
# K_SERVICE=service-name
# K_REVISION=revision-name