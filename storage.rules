rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the content
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to validate image uploads
    function isValidImage() {
      return request.resource.size < 10 * 1024 * 1024 && // Max 10MB
             request.resource.contentType.matches('image/.*');
    }
    
    // Helper function to validate video uploads  
    function isValidVideo() {
      return request.resource.size < 100 * 1024 * 1024 && // Max 100MB
             (request.resource.contentType.matches('video/.*') || 
              request.resource.contentType == 'application/octet-stream');
    }
    
    // Profile images - public read (profile pictures should be visible to all)
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true; // Public read for profile images
      allow write: if isOwner(userId) && isValidImage();
    }
    
    // Circle content - public read for images (includes misplaced profile images)
    match /circles/{circleId}/{allPaths=**} {
      allow read: if true; // Public read for circle images and misplaced profile images
      allow write: if isAuthenticated() && (isValidImage() || isValidVideo());
    }
    
    // Place photos - public read (place images should be shareable)
    match /places/{placeId}/{allPaths=**} {
      allow read: if true; // Public read for place photos
      allow write: if isAuthenticated() && isValidImage();
    }
    
    // Video content - public read for moments feature, owner-only write
    // Note: Videos are meant to be shared, so public read is intentional
    match /videos/{userId}/{type}/{allPaths=**} {
      allow read: if true; // Public read for shared moments
      allow write: if isOwner(userId) && isValidVideo();
    }
    
    // Alternative video path structure (if different)
    match /videos/{videoId}/{allPaths=**} {
      allow read: if true; // Public read for shared moments
      allow write: if isAuthenticated() && isValidVideo();
    }
    
    // User moments/reels - public read for sharing, owner can write
    match /moments/{userId}/{allPaths=**} {
      allow read: if true; // Public read for shared moments
      allow write: if isOwner(userId) && (isValidImage() || isValidVideo());
    }
    
    // Tutorial videos - public read for all users
    match /tutorial/{allPaths=**} {
      allow read: if true; // Public read for tutorial content
      allow write: if false; // No writes allowed (admin upload only)
    }
    
    // Temporary uploads - authenticated users only
    match /temp/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }
    
    // Default: deny all other access
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}